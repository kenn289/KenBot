# ════════════════════════════════════════════════════
#  KEN — ClawdBot Environment Configuration
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════════════

# ── AI Models ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...

# ── Media & Content ───────────────────────────────
ELEVENLABS_API_KEY=sk_...
PEXELS_API_KEY=...

# ── Social ────────────────────────────────────────
# Twitter/X (get from developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# ── Google / YouTube ──────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
# OAuth credentials file path (from Google Cloud Console)
GOOGLE_OAUTH_CREDENTIALS=./credentials/google_oauth.json

# ── Notion ────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=secret_...

# ── App Config ────────────────────────────────────
# Port for internal Flask API bridge
FLASK_PORT=5050
# Your WhatsApp number (international format, no + or spaces)
MY_WHATSAPP_NUMBER=91XXXXXXXXXX
# Groups where Ken is the REAL you (comma-separated, exact names)
KEN_REAL_GROUPS=Jaatre bois,Bengaluru big ball beasts
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Timezone
TIMEZONE=Asia/Kolkata
