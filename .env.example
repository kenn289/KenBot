# ====================================================
#  KenBot OS -- Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ====================================================

# ── AI Models ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...

# ── Media & Content ───────────────────────────────
ELEVENLABS_API_KEY=sk_...
PEXELS_API_KEY=...

# NewsAPI.org — optional, free tier 100 req/day, improves news quality
# Get key at: https://newsapi.org/register (takes 30 seconds)
# Without this key, RSS feeds (BBC/ToI/ESPN) are used directly (no key needed)
NEWS_API_KEY=
TAVILY_API_KEY=              # real-time web search — free at tavily.com (1000/month)

# -- Social ----------------------------------------------------
# Twitter/X API keys (from developer.twitter.com → your app → Keys & Tokens)
# IMPORTANT: App must have "Read and Write" permissions in developer.twitter.com
# After changing permissions, REGENERATE Access Token & Secret (old ones won't work)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Twitter/X login — used by Playwright browser fallback (if API keys not set)
# X may ask you to verify via email or phone during headless login.
# Set whichever you registered the account with:
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=                  # e.g. your@email.com
TWITTER_PHONE=                  # e.g. 919876543210 (no + or spaces)

# ── Google / YouTube ──────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
# OAuth credentials file path (from Google Cloud Console)
GOOGLE_OAUTH_CREDENTIALS=./credentials/google_oauth.json

# ── Notion ────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=secret_...

# ── Reddit (for automatic commenting) ─────────────
# Create script app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=KenBot/1.0 by Kenneth
REDDIT_AUTO_ENABLED=true

# ── Promotion Manager (controlled self-promo) ─────
PROMO_ENABLED=false
PROMO_REPO_URL=https://github.com/yourname/yourrepo
# comma-separated subreddit names (without r/), only these are eligible
PROMO_REDDIT_ALLOWLIST=sideproject,entrepreneur,startups,smallbusiness,indiehackers,programming,python,artificial,MachineLearning
# anti-spam limits
PROMO_X_DAILY_CAP=2
PROMO_REDDIT_DAILY_CAP=2
PROMO_X_COOLDOWN_MINUTES=360
PROMO_REDDIT_COOLDOWN_MINUTES=360

# ── App Config ────────────────────────────────────
# Port for internal Flask API bridge
FLASK_PORT=5050
# Your WhatsApp number (international format, no + or spaces)
MY_WHATSAPP_NUMBER=91XXXXXXXXXX
# Groups where Ken is the REAL you (comma-separated, exact names as they appear in WhatsApp)
KEN_REAL_GROUPS=My Friend Group,Another Group Name
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Timezone
TIMEZONE=Asia/Kolkata

# -- Chrome path for WhatsApp bot (Puppeteer) ------------------
# Leave blank to let Puppeteer auto-detect the bundled Chromium.
# Set this ONLY if you get a Chrome/Chromium not found error.
# Windows: C:\Users\YourName\.cache\puppeteer\chrome\win64-XXX\chrome-win64\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=
